{
  "name": "wechat-ilink-sdk",
  "version": "1.0.4",
  "description": "Universal TypeScript SDK for WeChat messaging with zero external dependencies",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "rollup -c",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^25.5.0",
    "rollup": "^4.9.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
