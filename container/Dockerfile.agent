# NanoClaw Agent Container
# Runs Pi Agent in isolated Linux VM with browser automation

FROM vt-claw-base:latest

# Set Chromium path for agent-browser
ENV AGENT_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Install agent-browser and claude-code globally
RUN npm install -g agent-browser @mariozechner/pi-coding-agent@0.60.0

# Create app directory
WORKDIR /app

# Copy package files first for better caching
COPY agent/package*.json ./
COPY agent/tsconfig.json ./
RUN npm install

# Copy python requirements, and install Python dependencies
COPY container/requirements.txt ./
RUN uv pip install --system -r requirements.txt -i https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple

# Create entrypoint script
COPY container/entrypoint.sh ./ 
RUN chmod +x ./entrypoint.sh

# Create workspace directories
RUN mkdir -p /workspace/group /workspace/extra /workspace/ipc/messages /workspace/ipc/tasks /workspace/ipc/input

# Set ownership to pn user (non-root) for writable directories
RUN chown -R pn:pn /workspace && chmod 777 /home/pn

# 安装 polymarket 工具
ENV https_proxy="http://127.0.0.1:7078"
ENV http_proxy="http://127.0.0.1:7078"
RUN curl -sSL https://raw.githubusercontent.com/Polymarket/polymarket-cli/main/install.sh | sh
ENV https_proxy=""
ENV http_proxy=""

RUN mkdir -p /home/pn/.config/polymarket
COPY container/config.json /home/pn/.config/polymarket/
RUN chown -R pn:pn /home/pn/.config/polymarket/config.json

# Switch to non-root user (required for --dangerously-skip-permissions)
USER pn

# Entry point reads JSON from stdin, outputs JSON to stdout
ENTRYPOINT ["/app/entrypoint.sh"]